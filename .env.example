# ─── WILLANA BOT – Variables de entorno ───────────────────────────────────
# Copiá este archivo como .env y completá los valores reales
# En Render, cargá estas variables en "Environment"

# Token que vos elegís para verificar el webhook con Meta (puede ser cualquier texto)
VERIFY_TOKEN=willana_token_2024

# Token de acceso de la API de WhatsApp Cloud (lo obtenés en Meta for Developers)
WA_TOKEN=REEMPLAZAR_CON_TU_TOKEN

# ID del número de teléfono (lo obtenés en Meta for Developers → Tu App → WhatsApp → Configuration)
PHONE_ID=REEMPLAZAR_CON_TU_PHONE_ID

# Puerto (Render lo asigna automáticamente, no tocar)
PORT=3000
